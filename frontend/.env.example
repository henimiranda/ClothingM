# Salin file ini menjadi .env.local dan isi nilainya

# Untuk lokal (Docker):
# NEXT_PUBLIC_API_URL=http://localhost:8080/api
# NEXT_PUBLIC_OAUTH_API_URL=http://localhost:8080/api

# Untuk lokal (langsung ke backend Laravel):
NEXT_PUBLIC_API_URL=http://localhost:5001/api
NEXT_PUBLIC_OAUTH_API_URL=http://localhost:5001/api

# Jika memakai backend Node lama untuk OAuth, tambahkan juga redirect URI ini
# di Google Console: http://localhost:5000/api/auth/google/callback

# Untuk Vercel production:
# NEXT_PUBLIC_API_URL=https://clothing-m-api.vercel.app/api
